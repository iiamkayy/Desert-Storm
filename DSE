-- Custom Hit Sound: the game's hit sounds are KillShot / HeadShot / LimbShot / TorsoShot
-- inside HitMarkerClient [LocalScript] which is parented to the LOCAL player's Character.
-- We hook Sound.Played on each of the 4 sounds so our sound fires every time they do.
local hitSoundConns = {}
local function hookHitMarkerSounds(char)
    -- clear old connections
    for _, c in pairs(hitSoundConns) do c:Disconnect() end
    hitSoundConns = {}
    if not char then return end
    local function attachTo(hmc)
        for _, snd in ipairs(hmc:GetChildren()) do
            if snd:IsA("Sound") then
                local conn = snd.Played:Connect(function()
                    if not Config.CustomHitSound or Config.CustomHitSoundID == "Default" then return end
                    -- Create a one-shot Sound in workspace so it plays globally
                    local s = Instance.new("Sound")
                    s.SoundId = Config.CustomHitSoundID
                    s.Volume  = Config.CustomHitSoundVolume
                    s.RollOffMaxDistance = 0
                    s.Parent = Workspace
                    s:Play()
                    game:GetService("Debris"):AddItem(s, 3)
                end)
                table.insert(hitSoundConns, conn)
            end
        end
    end
    -- HitMarkerClient may already be present or arrive shortly after spawn
    local hmc = char:FindFirstChild("HitMarkerClient")
    if hmc then
        attachTo(hmc)
    else
        local conn2 = char.ChildAdded:Connect(function(c)
            if c.Name == "HitMarkerClient" then attachTo(c) end
        end)
        table.insert(hitSoundConns, conn2)
    end
end

if plr.Character then hookHitMarkerSounds(plr.Character) end
