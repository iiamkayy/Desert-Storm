local ivAvatarCache = {}

local function ivGetFOVTarget()
    -- Returns the player closest to screen centre (no FOV gate — just nearest on-screen player)
    local screenCentre = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr and p.Character then
            local char = p.Character
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            if head then
                local sv, on = cam:WorldToViewportPoint(head.Position)
                if on then
                    local d = (Vector2.new(sv.X, sv.Y) - screenCentre).Magnitude
                    if d < bestDist then bestDist = d best = p end
                end
            end
        end
    end
    return best
end

