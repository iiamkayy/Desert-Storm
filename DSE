local function ivGetToolIcon(tool)
    -- 1) ItemIconID directly on the tool (confirmed from dump: M1911 has ItemIconID at tool level)
    local directIcon = tool:FindFirstChild("ItemIconID")
    if directIcon and directIcon:IsA("StringValue") and directIcon.Value ~= "" then
        return "rbxassetid://" .. directIcon.Value, nil
    end
    -- 2) SPH_Weapon Configuration sub-child (some tools store it there)
    local sphCfg = tool:FindFirstChild("SPH_Weapon")
    if sphCfg then
        local iv = sphCfg:FindFirstChild("ItemIconID") or sphCfg:FindFirstChild("WeaponIcon")
        if iv and iv:IsA("StringValue") and iv.Value ~= "" then
            return "rbxassetid://" .. iv.Value, nil
        end
    end
    -- 3) Grip > SpecialMesh TextureId (viewmodel gun grip)
    local grip = tool:FindFirstChild("Grip")
    if grip then
        local mesh = grip:FindFirstChildOfClass("SpecialMesh")
        if mesh and mesh.TextureId ~= "" then return mesh.TextureId, nil end
    end
    -- 4) Handle > SpecialMesh TextureId
    local handle = tool:FindFirstChild("Handle")
    if handle then
        local mesh = handle:FindFirstChildOfClass("SpecialMesh")
        if mesh and mesh.TextureId ~= "" then return mesh.TextureId, nil end
    end
    -- No icon found — return abbreviated name fallback
    return nil, tool.Name
end

-- Tier colour map (same as overhead ESP)
local IV_TIER = {
    [0]=Color3.fromRGB(160,160,160),[1]=Color3.fromRGB(100,200,100),
    [2]=Color3.fromRGB(80,140,255),[3]=Color3.fromRGB(180,80,255),[4]=Color3.fromRGB(255,180,0)
}

local ivLastTarget = nil

local function ivUpdate()
    if not InvViewGui.Enabled then return end
    local target = ivGetFOVTarget()

    if not target or not target.Character then
        ivName.Text = "Looking at: ---"
        ivVisLabel.Text = ""
        ivAvatar.Image = ""
        ivHpFill.Size = UDim2.new(0, 0, 1, 0)
        for _, s in ipairs(ivSlots) do
            s.Icon.Image = "" s.Icon.ImageTransparency = 1
            s.Label.Text = "" s.Stroke.Color = Color3.fromRGB(50,50,55)
        end
        return
    end

    if target ~= ivLastTarget then
        ivLastTarget = target
        ivLoadAvatar(target)
    end

    local char = target.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hp = hum and hum.Health or 0
    local maxHp = (hum and hum.MaxHealth > 0) and hum.MaxHealth or 100

    -- Distance in studs/meters
    local hrpIV = char:FindFirstChild("HumanoidRootPart")
    local distStr = ""
    if hrpIV then
        local d = math.floor((cam.CFrame.Position - hrpIV.Position).Magnitude)
        distStr = " [" .. (Config.StudsToMeters and math.floor(d/4) .. "m" or d .. "s") .. "]"
    end
    ivName.Text = target.Name .. distStr

    ivHpFill.Size = UDim2.new(math.clamp(hp / maxHp, 0, 1), 0, 1, 0)
    ivHpFill.BackgroundColor3 = Color3.fromRGB(80, 220, 80):Lerp(Color3.fromRGB(220, 60, 60), 1 - math.clamp(hp / maxHp, 0, 1))

    -- Visibility check
    local head = char:FindFirstChild("Head")
    if head then
        local rp2 = RaycastParams.new()
        rp2.FilterType = Enum.RaycastFilterType.Exclude
        rp2.FilterDescendantsInstances = {plr.Character or {}, char, cam}
        local r = Workspace:Raycast(cam.CFrame.Position, head.Position - cam.CFrame.Position, rp2)
        local vis = r == nil
        ivVisLabel.Text = vis and "VISIBLE" or "HIDDEN"
        ivVisLabel.TextColor3 = vis and Color3.fromRGB(60, 220, 60) or Color3.fromRGB(220, 60, 60)
    end

    -- Collect tools: equipped (in char) + hotbar (in Backpack), up to IV_SLOTS
    local tools = {}
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then table.insert(tools, c) end
    end
    local bp = target:FindFirstChildOfClass("Backpack") or target:FindFirstChild("Backpack")
    if bp then
        for _, c in ipairs(bp:GetChildren()) do
            if c:IsA("Tool") and #tools < IV_SLOTS then table.insert(tools, c) end
        end
    end

    -- Fill slots
    for i = 1, IV_SLOTS do
        local tool = tools[i]
        local s = ivSlots[i]
        if tool then
            local iconId, fallbackName = ivGetToolIcon(tool)
            -- Check for tier on the tool's SPH_Weapon or the tool itself
            local tierVal = tool:FindFirstChild("GearTier") or (tool:FindFirstChild("SPH_Weapon") and tool.SPH_Weapon:FindFirstChild("GearTier"))
            local tierColor = tierVal and (IV_TIER[math.floor(tierVal.Value)] or IV_TIER[0]) or IV_TIER[0]
            s.Stroke.Color = tierColor
            s.Stroke.Transparency = 0
            if iconId then
                s.Icon.Image = iconId
                s.Icon.ImageTransparency = 0
                s.Label.Text = ""
            else
                s.Icon.Image = ""
                s.Icon.ImageTransparency = 1
                s.Label.Text = fallbackName or tool.Name
            end
        else
            s.Icon.Image = "" s.Icon.ImageTransparency = 1
            s.Label.Text = ""
            s.Stroke.Color = Color3.fromRGB(50,50,55)
            s.Stroke.Transparency = 0.6
        end
    end
end

-- Update every 0.1s
task.spawn(function()
    while task.wait(0.1) do
        pcall(ivUpdate)
    end
end)

