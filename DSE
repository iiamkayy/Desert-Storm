local function applyGunMods(state)
    NoRecoilState = state
    for _, ammo in pairs(RS.AmmoTypes:GetChildren()) do
        if state then
            if not ammo:GetAttribute("OriginalRecoil") then ammo:SetAttribute("OriginalRecoil", ammo:GetAttribute("RecoilStrength")) end
            ammo:SetAttribute("RecoilStrength", 0)
            if not ammo:GetAttribute("OriginalAccuracy") then ammo:SetAttribute("OriginalAccuracy", ammo:GetAttribute("AccuracyDeviation")) end
            ammo:SetAttribute("AccuracyDeviation", 0)
        else
            if ammo:GetAttribute("OriginalRecoil") then ammo:SetAttribute("RecoilStrength", ammo:GetAttribute("OriginalRecoil")) end
            if ammo:GetAttribute("OriginalAccuracy") then ammo:SetAttribute("AccuracyDeviation", ammo:GetAttribute("OriginalAccuracy")) end
        end
    end
    if plr.Character then setupCharacter(plr.Character) end
end

