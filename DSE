                if track.Animation and track.Animation.Name == "Equip" then
                    track:AdjustSpeed(15)
                    track.TimePosition = track.Length - 0.01
                end
            end
        end

        if Config.NoFall and hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Landed)
        end
    end

    if Config.SpeedHackToggle and Config.SpeedHackActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = plr.Character.HumanoidRootPart
        local speed = Config.SpeedHackSpeed / (Config.SpeedHackSilent and 50 or 100)
        if UIS:IsKeyDown(Enum.KeyCode.W) then hrp.CFrame = hrp.CFrame + (cam.CFrame.LookVector * speed) end
        if UIS:IsKeyDown(Enum.KeyCode.S) then hrp.CFrame = hrp.CFrame - (cam.CFrame.LookVector * speed) end
        if UIS:IsKeyDown(Enum.KeyCode.A) then hrp.CFrame = hrp.CFrame - (cam.CFrame.RightVector * speed) end
        if UIS:IsKeyDown(Enum.KeyCode.D) then hrp.CFrame = hrp.CFrame + (cam.CFrame.RightVector * speed) end
    end

    if Config.MasterAimbot and Config.AimbotEnabled then
        local target = getTargetForLock()
        Config.LastTarget = target
        if target and target.Character and target.Character:FindFirstChild(Config.AimPart) then
            local tPart = target.Character:FindFirstChild(Config.AimPart)
            local tPos = tPart.Position
            local cPos = cam.CFrame.Position

            if Config.Prediction then
                local hrp = target.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (Vector3.new(tPos.X, 0, tPos.Z) - Vector3.new(cPos.X, 0, cPos.Z)).Magnitude
                    local timeToHit = dist / 800
                    tPos = tPos + (hrp.AssemblyLinearVelocity * timeToHit)
                end
            end

            if not Config.SilentAimbot then
                cam.CFrame = cam.CFrame:Lerp(CFrame.new(cPos, tPos), 1 / Config.AimbotSmoothness)
            end
        end
    else
        Config.LastTarget = nil
    end

    if BossFrame.Visible then
        -- Boss names confirmed from dump; also scan full Workspace for any boss model
        local BOSS_NAMES = {FireHawk=true,IronJaw=true,Tyrant=true,SwiftStrike=true,Anton=true,Dozer=true,Whisper=true,Death=true}
        local found = {}
        -- Primary: check Workspace.Bots
        local botsF = Workspace:FindFirstChild("Bots")
        if botsF then
            for _, m in pairs(botsF:GetChildren()) do
                if m:IsA("Model") and BOSS_NAMES[m.Name] and m:FindFirstChild("Humanoid") then
                    found[m.Name] = m
                end
            end
        end
        -- Fallback: scan entire Workspace for any boss-named Model (in case they spawn elsewhere)
        for _, m in pairs(Workspace:GetDescendants()) do
            if m:IsA("Model") and BOSS_NAMES[m.Name] and not found[m.Name] and m:FindFirstChild("Humanoid") then
                found[m.Name] = m
            end
        end
        local str = ""
        local order = {"FireHawk","IronJaw","Tyrant","SwiftStrike","Anton","Dozer","Whisper","Death"}
        for _, bossName in ipairs(order) do
            local boss = found[bossName]
            if boss then
                local hp = math.floor(boss.Humanoid.Health)
                local maxHp = math.floor(boss.Humanoid.MaxHealth)
                local pct = maxHp > 0 and math.floor((hp/maxHp)*100) or 0
                local hrpB = boss:FindFirstChild("HumanoidRootPart")
                local distStr = ""
                if hrpB and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local d = math.floor((plr.Character.HumanoidRootPart.Position - hrpB.Position).Magnitude)
                    distStr = " (" .. d .. "s)"
                end
                if hp > 0 then
                    str = str .. "🔴 " .. bossName .. ": " .. hp .. "/" .. maxHp .. " HP  " .. pct .. "%" .. distStr .. "\n"
                else
                    str = str .. "💀 " .. bossName .. ": Dead\n"
                end
            else
                str = str .. "⚪ " .. bossName .. ": Not Spawned\n"
            end
        end
        BossText.Text = str ~= "" and str or "No bosses found"
    end

    -- ViewModel Changer: colour/transparency every BasePart in WeaponRig (arms + weapon meshes)
    if Config.ViewModelChanger then
        local wr = cam:FindFirstChild("WeaponRig")
        if wr then
            for _, v in pairs(wr:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.Color        = Config.ArmColor
                    v.Transparency = Config.ViewModelTransparency
                end
            end
        end
    end

    -- FOV Changer
    local targetFOV = Config.FOVChangerEnabled and Config.FOVChangerValue or 70
    if math.abs(cam.FieldOfView - targetFOV) > 0.05 then
        cam.FieldOfView = cam.FieldOfView + (targetFOV - cam.FieldOfView) * 0.2
    end

    -- Time Changer (must be applied every frame; Roblox resets it otherwise)
    if Config.TimeChanger then
        Lighting.TimeOfDay = Config.CurrentTime
    end

    -- Ambient Changer
    if Config.AmbientChangerRGB then
        local t2 = tick() * Config.AmbientChangerRGBSpeed
        Lighting.Ambient = Color3.fromHSV(t2 % 1, 1, 1)
        Lighting.OutdoorAmbient = Color3.fromHSV((t2 + 0.33) % 1, 1, 1)
    elseif Config.AmbientChanger then
        Lighting.Ambient = Config.AmbientColor
        Lighting.OutdoorAmbient = Config.AmbientColor
    end

    -- Cloud Changer
    if Config.CloudChanger then
        local clouds = Workspace.Terrain:FindFirstChild("Clouds")
        if clouds then clouds.Color = Config.CloudColor end
    end
end)

