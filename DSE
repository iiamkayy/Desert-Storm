-- Helper: get a tight 2D bounding box for a character by projecting key body parts
local function getCharBox(char)
    local parts = {"Head", "HumanoidRootPart", "LeftFoot", "RightFoot", "LeftHand", "RightHand"}
    local minX, maxX, minY, maxY = math.huge, -math.huge, math.huge, -math.huge
    local anyOnScreen = false
    for _, pName in ipairs(parts) do
        local p = char:FindFirstChild(pName)
        if p then
            local sv, on = cam:WorldToViewportPoint(p.Position)
            if on then
                anyOnScreen = true
                if sv.X < minX then minX = sv.X end
                if sv.X > maxX then maxX = sv.X end
                if sv.Y < minY then minY = sv.Y end
                if sv.Y > maxY then maxY = sv.Y end
            end
        end
    end
    if not anyOnScreen then return nil end
    -- Add a small margin
    local margin = 4
    return Vector2.new(math.floor(minX - margin), math.floor(minY - margin)),
           Vector2.new(math.floor(maxX - minX + margin * 2), math.floor(maxY - minY + margin * 2))
end

RunService.RenderStepped:Connect(function()
    for player, obj in pairs(ESPObjects) do
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChild("Humanoid")

        if hrp and hum and hum.Health > 0 and Config.ESPEnabled and (not Config.TeamCheck or player.Team ~= plr.Team) then
            local _, onScreen = cam:WorldToViewportPoint(hrp.Position)
            local dist = (cam.CFrame.Position - hrp.Position).Magnitude

            if onScreen and dist <= Config.MaxDistance then
                local boxPos, boxSize = getCharBox(char)
                if not boxPos then
                    for _, v in pairs(obj) do
                        if typeof(v) ~= "table" and v.Visible ~= nil then v.Visible = false end
                    end
                    for _, l in pairs(obj.SkeletonLines) do l.Visible = false end
                    continue
                end

                if Config.ShowBox then
                    obj.Box.Size = boxSize obj.Box.Position = boxPos obj.Box.Color = Config.BoxColor obj.Box.Visible = true
                    obj.BoxOutline.Size = boxSize obj.BoxOutline.Position = boxPos obj.BoxOutline.Visible = true
                else
                    obj.Box.Visible = false obj.BoxOutline.Visible = false
                end

                if Config.ShowName then
                    obj.Name.Text     = player.Name
                    obj.Name.Position = Vector2.new(boxPos.X + boxSize.X / 2, boxPos.Y - 16)
                    obj.Name.Color    = Config.NameColor
                    obj.Name.Visible  = true
                else obj.Name.Visible = false end

                if Config.ShowHealth then
                    local hp = hum.Health / hum.MaxHealth
                    obj.HealthOutline.From = Vector2.new(boxPos.X - 6, boxPos.Y + boxSize.Y)
                    obj.HealthOutline.To   = Vector2.new(boxPos.X - 6, boxPos.Y)
                    obj.HealthOutline.Visible = true
                    obj.Health.From  = Vector2.new(boxPos.X - 5, boxPos.Y + boxSize.Y)
                    obj.Health.To    = Vector2.new(boxPos.X - 5, boxPos.Y + boxSize.Y - (hp * boxSize.Y))
                    obj.Health.Color = Config.HealthLowColor:Lerp(Config.HealthHighColor, hp)
                    obj.Health.Visible = true
                else
                    obj.Health.Visible = false obj.HealthOutline.Visible = false
                end

                if Config.ShowDistance then
                    obj.Distance.Text     = Config.StudsToMeters and math.floor(dist / 4) .. " Meters" or math.floor(dist) .. " Studs"
                    obj.Distance.Position = Vector2.new(boxPos.X + boxSize.X / 2, boxPos.Y + boxSize.Y + 2)
                    obj.Distance.Color    = Config.DistanceColor
                    obj.Distance.Visible  = true
                else obj.Distance.Visible = false end

                if Config.ActiveGun then
                    obj.ActiveGun.Text     = tostring(PlayerWeapons[player] or "None")
                    obj.ActiveGun.Position = Vector2.new(boxPos.X + boxSize.X / 2, boxPos.Y + boxSize.Y + 16)
                    obj.ActiveGun.Color    = Config.ActiveGunColor
                    obj.ActiveGun.Visible  = true
                else obj.ActiveGun.Visible = false end

                if Config.ShowSkeletons then
                    for i, bone in pairs(SkeletonBones) do
                        local p1 = char:FindFirstChild(bone[1])
                        local p2 = char:FindFirstChild(bone[2])
                        if p1 and p2 then
                            if not obj.SkeletonLines[i] then
                                obj.SkeletonLines[i] = Drawing.new("Line")
                                obj.SkeletonLines[i].Thickness = Config.SkeletonThickness
                                obj.SkeletonLines[i].Color     = Config.SkeletonsColor
                            end
                            local sp1, on1 = cam:WorldToViewportPoint(p1.Position)
                            local sp2, on2 = cam:WorldToViewportPoint(p2.Position)
                            if on1 and on2 then
                                obj.SkeletonLines[i].From    = Vector2.new(sp1.X, sp1.Y)
                                obj.SkeletonLines[i].To      = Vector2.new(sp2.X, sp2.Y)
                                obj.SkeletonLines[i].Visible = true
                            else
                                obj.SkeletonLines[i].Visible = false
                            end
                        elseif obj.SkeletonLines[i] then
                            obj.SkeletonLines[i].Visible = false
                        end
                    end
                else
                    for _, line in pairs(obj.SkeletonLines) do line.Visible = false end
                end
            else
                obj.Box.Visible = false obj.BoxOutline.Visible = false obj.Name.Visible = false
                obj.Health.Visible = false obj.HealthOutline.Visible = false
                obj.Distance.Visible = false obj.ActiveGun.Visible = false
                for _, line in pairs(obj.SkeletonLines) do line.Visible = false end
            end
        else
            obj.Box.Visible = false obj.BoxOutline.Visible = false obj.Name.Visible = false
            obj.Health.Visible = false obj.HealthOutline.Visible = false
            obj.Distance.Visible = false obj.ActiveGun.Visible = false
            for _, line in pairs(obj.SkeletonLines) do line.Visible = false end
        end
    end

    -- Chams Logic
    if Config.Chams then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= plr and p.Character then
                for _, part in pairs(p.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        if not part:GetAttribute("OMAChams") then
                            part:SetAttribute("OMAChams", true)
                            part:SetAttribute("OMAOrigMat", part.Material)
                            part:SetAttribute("OMAOrigColor", part.Color)
                            part:SetAttribute("OMAOrigTrans", part.Transparency)
                        end
                        part.Material    = Enum.Material[Config.ChamMaterial]
                        part.Color       = Config.ChamColor
                        part.Transparency = (Config.ChamMaterial == "ForceField") and 0.5 or 0
                    elseif part:IsA("Decal") then
                        if not part:GetAttribute("OMAChams") then
                            part:SetAttribute("OMAChams", true)
                            part:SetAttribute("OMAOrigTrans", part.Transparency)
                        end
                        part.Transparency = 1
                    end
                end
            end
        end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= plr and p.Character then
                for _, part in pairs(p.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part:GetAttribute("OMAChams") then
                        part.Material    = part:GetAttribute("OMAOrigMat")
                        part.Color       = part:GetAttribute("OMAOrigColor")
                        part.Transparency = part:GetAttribute("OMAOrigTrans")
                        part:SetAttribute("OMAChams", nil)
                    elseif part:IsA("Decal") and part:GetAttribute("OMAChams") then
                        part.Transparency = part:GetAttribute("OMAOrigTrans")
                        part:SetAttribute("OMAChams", nil)
                    end
                end
            end
        end
    end
end)

