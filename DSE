-- Layout constants
local MC_SLOT_SIZE = 26   -- px per icon square (base size at reference distance)
local MC_SLOT_GAP  = 3    -- px gap between squares
local MC_ICON_PAD  = 3    -- inner padding inside each square
local MC_SLOT_COUNT = 5   -- Helmet, Armor, Backpack, Weapon1, Weapon2
local MC_TOTAL_W   = MC_SLOT_COUNT * (MC_SLOT_SIZE + MC_SLOT_GAP) - MC_SLOT_GAP  -- 136px
local MC_REF_DIST  = 20   -- studs: size is 1:1 at this distance, shrinks beyond

-- Fallback placeholder icons (shown when slot is empty)
local MC_PLACEHOLDER = {
    Helmet   = "rbxassetid://10747373187",
    Armor    = "rbxassetid://6031068833",
    Backpack = "rbxassetid://5845451921",
    Weapon   = "rbxassetid://10889218683",
}

-- Border color per GearTier value (matches the game's tier system)
local MC_TIER_COLOR = {
    [0] = Color3.fromRGB(160, 160, 160),  -- common   (grey)
    [1] = Color3.fromRGB(100, 200, 100),  -- uncommon (green)
    [2] = Color3.fromRGB(80,  140, 255),  -- rare     (blue)
    [3] = Color3.fromRGB(180, 80,  255),  -- epic     (purple)
    [4] = Color3.fromRGB(255, 180, 0),    -- legendary(gold)
}
local MC_DEFAULT_TIER = Color3.fromRGB(160, 160, 160)

-- Returns the tier border color from an Accessory instance
local function mcTierColor(acc)
    local tv = acc:FindFirstChild("GearTier")
    if tv then return MC_TIER_COLOR[math.floor(tv.Value)] or MC_DEFAULT_TIER end
    return MC_DEFAULT_TIER
end

-- Builds one icon slot frame inside a parent, at the given x offset.
-- Returns: frame, icon ImageLabel, UIStroke, tier dot Frame
local function mcMakeSlot(parent, xOffset)
    local frame = Instance.new("Frame")
    frame.Size              = UDim2.new(0, MC_SLOT_SIZE, 0, MC_SLOT_SIZE)
    frame.Position          = UDim2.new(0, xOffset, 0, 0)
    frame.BackgroundColor3  = Color3.fromRGB(20, 20, 22)
    frame.BackgroundTransparency = 0.25
    frame.BorderSizePixel   = 0
    frame.Parent            = parent
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Thickness    = 1
    stroke.Color        = Color3.fromRGB(60, 60, 65)
    stroke.Transparency = 0.5
    stroke.Parent       = frame

    local icon = Instance.new("ImageLabel")
    icon.Name                   = "Icon"
    icon.Size                   = UDim2.new(0, MC_SLOT_SIZE - MC_ICON_PAD*2, 0, MC_SLOT_SIZE - MC_ICON_PAD*2)
    icon.Position               = UDim2.new(0, MC_ICON_PAD, 0, MC_ICON_PAD)
    icon.BackgroundTransparency = 1
    icon.Image                  = ""
    icon.ImageTransparency      = 1
    icon.ScaleType              = Enum.ScaleType.Fit
    icon.Parent                 = frame

    -- Small tier dot, bottom-right corner of the slot
    local dot = Instance.new("Frame")
    dot.Name            = "TierDot"
    dot.Size            = UDim2.new(0, 6, 0, 6)
    dot.Position        = UDim2.new(1, -8, 1, -8)
    dot.BorderSizePixel = 0
    dot.BackgroundColor3 = MC_DEFAULT_TIER
    dot.Visible         = false
    dot.Parent          = frame
    local dc = Instance.new("UICorner")
    dc.CornerRadius = UDim.new(1, 0)
    dc.Parent = dot

    return frame, icon, stroke, dot
end

-- Fills a slot with a real icon + tier colour, or blanks it if empty.
local function mcFillSlot(slotData, iconId, tierColor, isEmpty)
    if isEmpty or not iconId or iconId == "" then
        slotData.Icon.Image            = ""
        slotData.Icon.ImageTransparency = 1
        slotData.Stroke.Color          = Color3.fromRGB(50, 50, 55)
        slotData.Dot.Visible           = false
    else
        slotData.Icon.Image            = iconId
        slotData.Icon.ImageTransparency = 0
        slotData.Stroke.Color          = tierColor or MC_DEFAULT_TIER
        slotData.Stroke.Transparency   = 0
        if tierColor then
            slotData.Dot.BackgroundColor3 = tierColor
            slotData.Dot.Visible = true
        end
    end
end

-- Shortens a weapon tool name so it fits in the small slot label.
local function mcShortName(name)
    name = name:gsub(" IAR",""):gsub(" Rifle",""):gsub(" Pistol",""):gsub(" SMG",""):gsub(" LMG",""):gsub(" Sniper","")
    if #name > 8 then name = name:sub(1, 7) .. "." end
    return name
end

-- Builds (or rebuilds) the full BillboardGui on a player's Head.
-- Returns the billboard root, a slots table, and the name TextLabel.
local function mcBuildBillboard(player)
    local char = player.Character
    if not char then return nil end
    local head = char:FindFirstChild("Head")
    if not head then return nil end

    -- Destroy any previous version
    local old = head:FindFirstChild("OMAMinecraftESP")
    if old then old:Destroy() end

    local bb = Instance.new("BillboardGui")
    bb.Name           = "OMAMinecraftESP"
    bb.AlwaysOnTop    = true
    bb.StudsOffset    = Vector3.new(0, 2.8, 0)
    bb.Size           = UDim2.new(0, MC_TOTAL_W, 0, MC_SLOT_SIZE + 18)
    bb.LightInfluence = 0
    bb.Parent         = head

    -- Icon row container
    local iconRow = Instance.new("Frame")
    iconRow.Name                  = "IconRow"
    iconRow.Size                  = UDim2.new(0, MC_TOTAL_W, 0, MC_SLOT_SIZE)
    iconRow.Position              = UDim2.new(0, 0, 0, 0)
    iconRow.BackgroundTransparency = 1
    iconRow.Parent                = bb

    -- Build all 5 slots
    local slotNames = {"Helmet", "Armor", "Backpack", "Weapon1", "Weapon2"}
    local slots = {}
    for i, sName in ipairs(slotNames) do
        local xOff = (i - 1) * (MC_SLOT_SIZE + MC_SLOT_GAP)
        local frame, icon, stroke, dot = mcMakeSlot(iconRow, xOff)
        slots[sName] = {Frame = frame, Icon = icon, Stroke = stroke, Dot = dot}
    end

    -- Name + distance bar below the icons
    local nameRow = Instance.new("Frame")
    nameRow.Name                  = "NameRow"
    nameRow.Size                  = UDim2.new(1, 0, 0, 22)
    nameRow.Position              = UDim2.new(0, 0, 0, MC_SLOT_SIZE + 4)
    nameRow.BackgroundColor3      = Color3.fromRGB(12, 12, 14)
    nameRow.BackgroundTransparency = 0.3
    nameRow.BorderSizePixel       = 0
    nameRow.Parent                = bb
    local nc = Instance.new("UICorner")
    nc.CornerRadius = UDim.new(0, 4)
    nc.Parent = nameRow

    local nameLbl = Instance.new("TextLabel")
    nameLbl.Name                  = "NameLabel"
    nameLbl.Size                  = UDim2.new(1, -4, 1, 0)
    nameLbl.Position              = UDim2.new(0, 2, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text                  = player.Name
    nameLbl.Font                  = Enum.Font.GothamBold
    nameLbl.TextSize              = 11
    nameLbl.TextColor3            = Color3.fromRGB(240, 240, 245)
    nameLbl.TextStrokeTransparency = 0.6
    nameLbl.TextXAlignment        = Enum.TextXAlignment.Center
    nameLbl.Parent                = nameRow

    return bb, slots, nameLbl
end

-- Per-player billboard cache: [player] = {BB, Slots, NameLabel}
local mcCache = {}

-- Scans the character and populates all 5 slots + the name bar.
local function mcUpdatePlayer(player)
    if not Config.OverheadInvESP then return end
    if player == plr then return end

    local char = player.Character
    local head = char and char:FindFirstChild("Head")
    if not char or not head then return end

    -- Rebuild if missing (e.g. after respawn)
    local cached = mcCache[player]
    if not cached or not head:FindFirstChild("OMAMinecraftESP") then
        local bb, slots, nameLbl = mcBuildBillboard(player)
        if not bb then return end
        mcCache[player] = {BB = bb, Slots = slots, NameLabel = nameLbl}
        cached = mcCache[player]
    end

    local slots  = cached.Slots
    local nameLbl = cached.NameLabel

    -- ── Scan accessories by type tag ──────────────────────
    local helmetAcc, armorAcc, backpackAcc = nil, nil, nil
    for _, acc in ipairs(char:GetChildren()) do
        if acc:IsA("Accessory") then
            local hTag = acc:FindFirstChild("Helmet")
            local aTag = acc:FindFirstChild("BodyArmor")
            local bTag = acc:FindFirstChild("Backpack")
            if hTag and hTag.Value then helmetAcc   = acc end
            if aTag and aTag.Value then armorAcc    = acc end
            if bTag and bTag.Value then backpackAcc = acc end
        end
    end

    -- Helmet slot
    if helmetAcc and helmetAcc:FindFirstChild("ItemIconID") and helmetAcc.ItemIconID.Value ~= "" then
        mcFillSlot(slots.Helmet, "rbxassetid://" .. helmetAcc.ItemIconID.Value, mcTierColor(helmetAcc), false)
    else
        mcFillSlot(slots.Helmet, MC_PLACEHOLDER.Helmet, nil, true)
    end

    -- Armor slot
    if armorAcc and armorAcc:FindFirstChild("ItemIconID") and armorAcc.ItemIconID.Value ~= "" then
        mcFillSlot(slots.Armor, "rbxassetid://" .. armorAcc.ItemIconID.Value, mcTierColor(armorAcc), false)
    else
        mcFillSlot(slots.Armor, MC_PLACEHOLDER.Armor, nil, true)
    end

    -- Backpack slot
    if backpackAcc and backpackAcc:FindFirstChild("ItemIconID") and backpackAcc.ItemIconID.Value ~= "" then
        mcFillSlot(slots.Backpack, "rbxassetid://" .. backpackAcc.ItemIconID.Value, mcTierColor(backpackAcc), false)
    else
        mcFillSlot(slots.Backpack, MC_PLACEHOLDER.Backpack, nil, true)
    end

    -- ── Scan weapons (character Tools first, then Backpack) ──
    local weapons = {}
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") then table.insert(weapons, t) end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and #weapons < 2 then table.insert(weapons, t) end
        end
    end

    -- Resolve an icon for a Tool — mirrors ivGetToolIcon exactly.
    local function weaponIcon(tool)
        -- 1) ItemIconID directly on the Tool (confirmed from dump: every gun has this)
        local direct = tool:FindFirstChild("ItemIconID")
        if direct and direct:IsA("StringValue") and direct.Value ~= "" then
            return "rbxassetid://" .. direct.Value
        end
        -- 2) SPH_Weapon Configuration child
        local sphCfg = tool:FindFirstChild("SPH_Weapon")
        if sphCfg then
            local iv = sphCfg:FindFirstChild("ItemIconID") or sphCfg:FindFirstChild("WeaponIcon")
            if iv and iv:IsA("StringValue") and iv.Value ~= "" then
                return "rbxassetid://" .. iv.Value
            end
        end
        -- 3) Grip > SpecialMesh TextureId
        local grip = tool:FindFirstChild("Grip")
        if grip then
            local mesh = grip:FindFirstChildOfClass("SpecialMesh")
            if mesh and mesh.TextureId ~= "" then return mesh.TextureId end
        end
        -- 4) Handle > SpecialMesh TextureId
        local handle = tool:FindFirstChild("Handle")
        if handle then
            local mesh = handle:FindFirstChildOfClass("SpecialMesh")
            if mesh and mesh.TextureId ~= "" then return mesh.TextureId end
        end
        return nil
    end

    local wSlots = {"Weapon1", "Weapon2"}
    for i = 1, 2 do
        local tool = weapons[i]
        local sd   = slots[wSlots[i]]
        if tool then
            local icon = weaponIcon(tool)
            if icon then
                -- Found a real icon — show it with a white border
                mcFillSlot(sd, icon, Color3.fromRGB(255, 255, 255), false)
                -- Remove any leftover name label from a previous cycle
                local lbl = sd.Frame:FindFirstChild("WepName")
                if lbl then lbl.Visible = false end
            else
                -- No icon found — show placeholder dimmed + abbreviated name
                sd.Icon.Image            = MC_PLACEHOLDER.Weapon
                sd.Icon.ImageTransparency = 0.5
                sd.Stroke.Color          = Color3.fromRGB(255, 200, 50)
                sd.Stroke.Transparency   = 0
                sd.Dot.Visible           = false

                local lbl = sd.Frame:FindFirstChild("WepName")
                if not lbl then
                    lbl = Instance.new("TextLabel")
                    lbl.Name                   = "WepName"
                    lbl.Size                   = UDim2.new(1, -2, 0, 10)
                    lbl.Position               = UDim2.new(0, 1, 1, -12)
                    lbl.BackgroundTransparency  = 1
                    lbl.Font                   = Enum.Font.GothamBold
                    lbl.TextSize               = 7
                    lbl.TextColor3             = Color3.fromRGB(255, 200, 50)
                    lbl.TextXAlignment         = Enum.TextXAlignment.Center
                    lbl.TextTruncate           = Enum.TextTruncate.AtEnd
                    lbl.Parent                 = sd.Frame
                end
                lbl.Text    = mcShortName(tool.Name)
                lbl.Visible = true
            end
        else
            -- Slot is empty
            mcFillSlot(sd, MC_PLACEHOLDER.Weapon, nil, true)
            local lbl = sd.Frame:FindFirstChild("WepName")
            if lbl then lbl.Visible = false end
        end
    end

    -- ── Name + distance bar ───────────────────────────────
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local dist  = math.floor((cam.CFrame.Position - hrp.Position).Magnitude)
        local dVal  = Config.StudsToMeters and math.floor(dist / 4) or dist
        local dUnit = Config.StudsToMeters and "m" or "s"
        nameLbl.Text = player.Name .. "  [" .. dVal .. dUnit .. "]"
    else
        nameLbl.Text = player.Name
    end
end

-- Destroys a player's cached billboard and removes the cache entry.
local function mcClean(player)
    local cached = mcCache[player]
    if cached and cached.BB and cached.BB.Parent then
        cached.BB:Destroy()
    end
    mcCache[player] = nil
end

-- Hook respawn: rebuild billboard fresh after a short delay
-- (needed so accessories are fully loaded onto the new character)
local function mcHookRespawn(player)
    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        mcClean(player)
    end)
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= plr then mcHookRespawn(p) end
end
Players.PlayerAdded:Connect(function(p)
    if p ~= plr then mcHookRespawn(p) end
end)
Players.PlayerRemoving:Connect(mcClean)

-- Main update loop: runs at 0.4s intervals, light on performance
task.spawn(function()
    while task.wait(0.4) do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= plr then
                if Config.OverheadInvESP then
                    -- Distance gate: hide billboard if player is beyond MaxESP distance
                    local char = p.Character
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local dist = (cam.CFrame.Position - hrp.Position).Magnitude
                        if dist > Config.MaxDistance then
                            -- Outside range — hide without destroying cache
                            local cached = mcCache[p]
                            if cached and cached.BB then
                                cached.BB.Enabled = false
                            end
                        else
                            mcUpdatePlayer(p)
                            -- Scale billboard size so it doesn't balloon at long range
                            local cached = mcCache[p]
                            if cached and cached.BB then
                                local scale = math.clamp(MC_REF_DIST / dist, 0.25, 1)
                                local w = math.floor(MC_TOTAL_W * scale)
                                local h = math.floor((MC_SLOT_SIZE + 18) * scale)
                                cached.BB.Size    = UDim2.new(0, w, 0, h)
                                cached.BB.Enabled = true
                            end
                        end
                    else
                        -- No HRP yet (loading) — just run normal update
                        mcUpdatePlayer(p)
                    end
                else
                    mcClean(p)
                end
            end
        end
    end
end)

