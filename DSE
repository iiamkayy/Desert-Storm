getgenv().sneeky_silent_aim = false
getgenv().sneeky_fov_size = 200
getgenv().sneeky_wallcheck = true

local veh, sph, bots = Workspace:FindFirstChild("Vehicles"), Workspace:FindFirstChild("SPH_Workspace"), Workspace:FindFirstChild("Bots")
local rp = RaycastParams.new()
rp.FilterType = Enum.RaycastFilterType.Exclude
rp.IgnoreWater = true

local function isVisible(part, origin)
    local char = plr.Character
    if not (char and part) then return false, nil end
    rp.FilterDescendantsInstances = {char, veh, sph}
    local dir = part.Position - origin
    local result = Workspace:Raycast(origin, dir, rp)
    if not result then return true, nil end
    if result.Instance:IsDescendantOf(part.Parent) then return true, result.Instance end
    return false, result.Instance
end

local function getTarget(origin)
    if not getgenv().sneeky_silent_aim then return nil end
    local cPart, cDistance, cPos = nil, getgenv().sneeky_fov_size or 300, nil
    local t = {}
    for _, v in pairs(Players:GetPlayers()) do table.insert(t, v) end
    if bots then
        for _, v in pairs(bots:GetChildren()) do table.insert(t, v) end
    end

    local screenCenter = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)

    for _, v in pairs(t) do
        if v ~= plr then
            local char = v:IsA("Model") and v or v.Character
            if char and not char:FindFirstChildOfClass("ForceField") then
                local hum = char:FindFirstChild("Humanoid")
                if not hum or hum.Health > 0 then
                    local tPart = char:FindFirstChild("Head") or char.PrimaryPart or char:FindFirstChild("HumanoidRootPart")
                    if tPart then
                        local pos, onScreen = cam:WorldToViewportPoint(tPart.Position)
                        if onScreen then
                            local vis, nTPart = isVisible(tPart, origin)
                            if not vis and getgenv().sneeky_wallcheck then
                                vis, nTPart = isVisible(char.PrimaryPart or char:FindFirstChild("HumanoidRootPart"), origin)
                            end
                            if vis then
                                if nTPart then tPart = nTPart end
                                local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                                if dist < cDistance then
                                    cPart = tPart
                                    cPos = tPart.Position
                                    cDistance = dist
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return cPart, cPos
end

-- Hook FastCast (Sneeky's Silent Aim)
local s, ac = pcall(require, RS.SPH_Assets.Modules.FastCast.ActiveCast)
if s then
    local old; old = clonefunction(hookfunction(rawget(ac, "new"), newcclosure(function(_, origin, __, ___, ...)
        local c, pos = getTarget(origin)
        if c and pos then
            local dir = pos - origin
            return old(_, origin, dir, dir.Unit * 9e9, ...)
        end
        return old(_, origin, __, ___, ...)
    end)))
end

-- Bullet Tracer Drawing
local function drawTracer(startPos, endPos)
    local p1 = Instance.new("Part")
    p1.Anchored = true p1.CanCollide = false p1.Transparency = 1 p1.CFrame = CFrame.new(startPos) p1.Parent = Workspace
    local p2 = Instance.new("Part")
    p2.Anchored = true p2.CanCollide = false p2.Transparency = 1 p2.CFrame = CFrame.new(endPos) p2.Parent = Workspace

    local a1 = Instance.new("Attachment", p1)
    local a2 = Instance.new("Attachment", p2)
    local beam = Instance.new("Beam", p1)
    beam.Attachment0 = a1 beam.Attachment1 = a2
    beam.Color = ColorSequence.new(Config.BulletTracerColor)
    beam.Width0 = 0.2 beam.Width1 = 0.2 beam.FaceCamera = true
    beam.Texture = Config.BulletTracerTexture

    game:GetService("Debris"):AddItem(p1, 0.1)
    game:GetService("Debris"):AddItem(p2, 0.1)
end

cam.DescendantAdded:Connect(function(d)
    if not Config.BulletTracer then return end
    -- Muzzle flash particles are named Flash*, SmokePuff, SmokeCloud, SmokeTrail inside Muzzle attachment
    if d:IsA("ParticleEmitter") and d.Parent and d.Parent.Name == "Muzzle" then
        local wr = cam:FindFirstChild("WeaponRig")
        if not wr then return end
        local weaponFolder = wr:FindFirstChild("Weapon")
        if not weaponFolder then return end
        -- Walk into the gun model to find Grip > Muzzle attachment position
        for _, gun in pairs(weaponFolder:GetChildren()) do
            local grip = gun:FindFirstChild("Grip")
            if grip then
                local muzzleAttach = grip:FindFirstChild("Muzzle")
                local startPos = muzzleAttach and muzzleAttach.WorldPosition or grip.Position
                local lookDir = cam.CFrame.LookVector
                local ray = Workspace:Raycast(startPos, lookDir * 3500, RaycastParams.new())
                local endPos = ray and ray.Position or (startPos + lookDir * 3500)
                drawTracer(startPos, endPos)
                return
            end
        end
    end
end)

