-- Helper: get a 3D world position for a Model — tries PrimaryPart, then first BasePart
local function getModelAnchor(model)
    if model:IsA("BasePart") then return model end
    if model.PrimaryPart then return model.PrimaryPart end
    for _, d in pairs(model:GetDescendants()) do
        if d:IsA("BasePart") then return d end
    end
    return nil
end

-- Helper: read non-empty slots from a Slots folder, return comma-separated string (max ~6 items shown)
local function readSlots(model)
    local slotsFolder = model:FindFirstChild("Slots")
    if not slotsFolder then return nil end
    local items = {}
    for _, slot in pairs(slotsFolder:GetChildren()) do
        local iv = slot:FindFirstChild("ItemName")
        if iv and iv.Value ~= "" then
            local stack = slot:FindFirstChild("Stack")
            local entry = iv.Value
            if stack and stack.Value > 1 then entry = entry .. "x" .. stack.Value end
            table.insert(items, entry)
            if #items >= 6 then break end
        end
    end
    return #items > 0 and table.concat(items, ", ") or nil
end

-- Helper: read worn gear names from a corpse/character model
local function readCorpseGear(model)
    local gear = {}
    for _, acc in pairs(model:GetChildren()) do
        if acc:IsA("Accessory") then
            local isGear = acc:FindFirstChild("Helmet") or acc:FindFirstChild("BodyArmor") or acc:FindFirstChild("Backpack") or acc:FindFirstChild("Facemask")
            if isGear then table.insert(gear, acc.Name) end
        end
    end
    return #gear > 0 and table.concat(gear, " | ") or "No Gear"
end

-- Helper: check whether a world position is within WorldESPMaxDistance from camera
local function inWorldRange(pos)
    return (cam.CFrame.Position - pos).Magnitude <= Config.WorldESPMaxDistance
end

-- World ESP scan loop (1s tick)
task.spawn(function()
    while task.wait(1) do
        -- ── Workspace.Containers: Corpses, DroppedItems, Containers (incl. Vault) ──
        local containers = Workspace:FindFirstChild("Containers")
        if containers then
            -- Use GetDescendants to catch items nested inside sub-folders
            for _, obj in pairs(containers:GetDescendants()) do
                if (obj:IsA("Model") or obj:IsA("MeshPart") or obj:IsA("BasePart")) and obj.Parent ~= nil then
                    local anchor = getModelAnchor(obj)
                    if not anchor then continue end
                    if not inWorldRange(anchor.Position) then
                        -- out of range — remove existing tag
                        local b = obj:FindFirstChild("OMAWareESP") if b then b:Destroy() end
                        continue
                    end

                    -- CORPSE ESP
                    if obj:FindFirstChild("CorpseOwner") then
                        if Config.CorpseESP then
                            local ownerVal = obj:FindFirstChild("CorpseOwner")
                            local ownerName = ownerVal and ownerVal.Value ~= "" and ownerVal.Value or obj.Name
                            local gear = readCorpseGear(obj)
                            local inv  = readSlots(obj)
                            local lines = "☠ " .. ownerName .. "\n" .. gear
                            if inv then lines = lines .. "\n[" .. inv .. "]" end
                            local existing = obj:FindFirstChild("OMAWareESP")
                            if existing then existing:Destroy() end
                            addBillboard(anchor, lines, Config.CorpseColor)
                        else
                            local b = obj:FindFirstChild("OMAWareESP") if b then b:Destroy() end
                        end

                    -- VAULT EXTRACTION ESP (Vault is inside Containers, has ExtractUI)
                    elseif obj.Name == "Vault" and obj:FindFirstChild("ExtractUI") then
                        if Config.ExtractionESP then
                            local existing = obj:FindFirstChild("OMAWareESP") if existing then existing:Destroy() end
                            addBillboard(anchor, "⬆ VAULT (extract)", Config.ExtractionColor)
                        else
                            local b = obj:FindFirstChild("OMAWareESP") if b then b:Destroy() end
                        end

                    -- DROPPED ITEM ESP — DroppedItemContainer children
                    elseif obj.Parent and obj.Parent.Name == "DroppedItemContainer" then
                        if Config.DroppedItemESP then
                            local inv = readSlots(obj)
                            local label = "⬇ " .. (inv or obj.Name)
                            local existing = obj:FindFirstChild("OMAWareESP") if existing then existing:Destroy() end
                            addBillboard(anchor, label, Config.DroppedItemColor)
                        else
                            local b = obj:FindFirstChild("OMAWareESP") if b then b:Destroy() end
                        end

                    -- LOOT CONTAINER ESP — whitelisted container types
                    elseif ContainerWhitelist[obj.Name] then
                        if Config.ContainerESP then
                            local inv = readSlots(obj)
                            local label = obj.Name .. (inv and ("\n" .. inv) or "\n[Empty]")
                            local existing = obj:FindFirstChild("OMAWareESP") if existing then existing:Destroy() end
                            addBillboard(anchor, label, Config.ContainerColor)
                        else
                            local b = obj:FindFirstChild("OMAWareESP") if b then b:Destroy() end
                        end
                    end
                end
            end
        end

        -- ── Workspace.Extractions: the 10 real extraction points ──────────────
        local extractions = Workspace:FindFirstChild("Extractions")
        if extractions then
            for _, extractPart in pairs(extractions:GetChildren()) do
                if extractPart:IsA("BasePart") then
                    -- Remove any stale billboard first
                    local old = extractPart:FindFirstChild("OMAWareExtract")
                    if not inWorldRange(extractPart.Position) then
                        if old then old:Destroy() end
                    elseif Config.ExtractionESP then
                        local availVal = extractPart:FindFirstChild("Available")
                        local isOpen   = availVal and availVal.Value or false
                        -- Rebuild every tick so status stays live
                        if old then old:Destroy() end

                        -- Compact sleek BillboardGui
                        local bb = Instance.new("BillboardGui")
                        bb.Name          = "OMAWareExtract"
                        bb.AlwaysOnTop   = true
                        bb.StudsOffset   = Vector3.new(0, 3.5, 0)
                        bb.Size          = UDim2.new(0, 120, 0, 36)
                        bb.LightInfluence = 0
                        bb.Parent        = extractPart

                        -- Pill background
                        local bg = Instance.new("Frame", bb)
                        bg.Size                  = UDim2.new(1, 0, 1, 0)
                        bg.BackgroundColor3      = Color3.fromRGB(10, 10, 12)
                        bg.BackgroundTransparency = 0.25
                        bg.BorderSizePixel       = 0
                        local bgC = Instance.new("UICorner", bg) bgC.CornerRadius = UDim.new(1, 0)
                        local bgS = Instance.new("UIStroke", bg)
                        bgS.Thickness    = 1
                        bgS.Color        = isOpen and Color3.fromRGB(40, 220, 80) or Config.ExtractionColor
                        bgS.Transparency = 0.1

                        -- Status dot
                        local dot = Instance.new("Frame", bg)
                        dot.Size             = UDim2.new(0, 7, 0, 7)
                        dot.Position         = UDim2.new(0, 8, 0.5, -3)
                        dot.BackgroundColor3 = isOpen and Color3.fromRGB(40, 220, 80) or Color3.fromRGB(200, 60, 60)
                        dot.BorderSizePixel  = 0
                        local dotC = Instance.new("UICorner", dot) dotC.CornerRadius = UDim.new(1, 0)

                        -- Name label
                        local lbl = Instance.new("TextLabel", bg)
                        lbl.Size                   = UDim2.new(1, -22, 0.55, 0)
                        lbl.Position               = UDim2.new(0, 18, 0, 1)
                        lbl.BackgroundTransparency = 1
                        lbl.Text                   = extractPart.Name
                        lbl.Font                   = Enum.Font.GothamBold
                        lbl.TextSize               = 10
                        lbl.TextColor3             = Color3.fromRGB(240, 240, 245)
                        lbl.TextXAlignment         = Enum.TextXAlignment.Left
                        lbl.TextTruncate           = Enum.TextTruncate.AtEnd

                        -- Status label
                        local slbl = Instance.new("TextLabel", bg)
                        slbl.Size                   = UDim2.new(1, -18, 0.45, 0)
                        slbl.Position               = UDim2.new(0, 18, 0.55, 0)
                        slbl.BackgroundTransparency = 1
                        slbl.Text                   = isOpen and "OPEN" or "CLOSED"
                        slbl.Font                   = Enum.Font.GothamSemibold
                        slbl.TextSize               = 9
                        slbl.TextColor3             = isOpen and Color3.fromRGB(40, 220, 80) or Color3.fromRGB(200, 100, 100)
                        slbl.TextXAlignment         = Enum.TextXAlignment.Left
                    else
                        if old then old:Destroy() end
                    end
                end
            end
        end

        -- ── AI Billboard Tags + Chams ─────────────────────────────────────────
        local function scanAIs(folder)
            if not folder then return end
            for _, bot in pairs(folder:GetChildren()) do
                if bot:IsA("Model") and bot:FindFirstChild("Humanoid") then
                    -- ensure Drawing ESP object exists
                    if not NPCESPObjects[bot] then createNPCESPObjects(bot) end
                    -- billboard nametag
                    if Config.AINameTag then
                        if not bot:FindFirstChild("OMAWareESP") then
                            addBillboard(bot.PrimaryPart or bot:FindFirstChild("Head"), bot.Name .. " | NPC", Config.NameTagColor)
                        end
                    else
                        local b = bot:FindFirstChild("OMAWareESP") if b then b:Destroy() end
                    end
                    -- Highlight chams
                    if Config.AIHighlight then
                        if not bot:FindFirstChild("OMAWareAIChams") then
                            local h = Instance.new("Highlight")
                            h.Name = "OMAWareAIChams"
                            h.FillColor = Config.HighlightColor
                            h.OutlineColor = Config.HighlightColor
                            h.Parent = bot
                        end
                    else
                        local h = bot:FindFirstChild("OMAWareAIChams") if h then h:Destroy() end
                    end
                end
            end
        end
        scanAIs(Workspace:FindFirstChild("Bots"))
        scanAIs(Workspace:FindFirstChild("HQNpcs"))
    end
end)

